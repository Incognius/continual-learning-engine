# Copy to `.env` and adjust as needed. These override values in configs/config.yaml.
# Convention: CML_<SECTION>__<KEY>  (double underscore = nesting).

# Path to the YAML config the app loads at startup.
CML_CONFIG_PATH=configs/config.yaml

# --- Example overrides (uncomment to use) ------------------------------------
# CML_APP__ENVIRONMENT=production
# CML_APP__LOG_LEVEL=DEBUG
# CML_STREAM__RATE_PER_SEC=50
# CML_DATA_SOURCE__TYPE=synthetic

# --- MLflow ------------------------------------------------------------------
# Inside docker-compose the service hostname is `mlflow`.
# For running the API on the host (outside Docker), use localhost.
CML_MLFLOW__TRACKING_URI=http://mlflow:5000
# MLFLOW_TRACKING_URI is read by the mlflow client library itself.
MLFLOW_TRACKING_URI=http://mlflow:5000
